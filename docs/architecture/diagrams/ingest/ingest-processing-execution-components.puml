@startuml
title Ingest 处理执行组件图（DDD-Lite，当前实现）

skinparam componentStyle rectangle
skinparam shadowing false
skinparam linetype ortho

actor "客户端/前端" as Client

package "Interfaces" {
  component "DocumentIngestController\nPOST /upload\nGET /{id}/status\nGET /{id}/chunks/preview" as Controller
}

package "Application" {
  component "AcceptUploadUseCase" as AcceptUC
  component "GetDocumentStatusUseCase" as StatusUC
  component "GetDocumentChunksPreviewUseCase" as PreviewUC
  component "ClaimNextUploadedDocumentUseCase" as ClaimUC
  component "ProcessDocumentUseCase" as ProcessUC
}

package "Domain Ports" {
  component "DocumentRepository Port" as DocRepoPort
  component "DocumentIdGenerator Port" as IdPort
  component "DocumentSourceStorage Port" as SourceStoragePort
  component "DocumentTextParser Port" as ParserPort
  component "DocumentChunker Port" as ChunkerPort
  component "DocumentVectorIndexer Port" as VectorPort
  component "DocumentChunkPreviewRepository Port" as PreviewRepoPort
}

package "Infrastructure" {
  component "InProcessWorker" as Worker
  component "JdbcDocumentRepository" as JdbcRepo
  component "UuidDocumentIdGenerator" as UuidGen
  component "LocalDocumentSourceStorage" as LocalStorage
  component "TikaDocumentTextParser\n+ TextCleaningService" as TikaParser
  component "StructuredFallbackDocumentChunker" as ChunkerAdapter
  component "PgVectorDocumentVectorIndexer" as PgVectorAdapter
  component "JdbcDocumentChunkPreviewRepository" as JdbcPreviewRepo
}

database "PostgreSQL\ningest_documents + vector_store" as PG
collections "Local FS\n{root}/{documentId}/{filename}" as FS
cloud "Embedding API\n(OpenAI via Spring AI)" as EmbAPI

Client --> Controller : HTTP API

Controller --> AcceptUC : upload
Controller --> StatusUC : status
Controller --> PreviewUC : chunks preview
Controller --> SourceStoragePort : 保存源文件（幂等）

Worker --> ClaimUC : pollAndClaim()
Worker --> ProcessUC : handle(documentId)

AcceptUC --> IdPort
AcceptUC --> DocRepoPort
StatusUC --> DocRepoPort
PreviewUC --> DocRepoPort
PreviewUC --> PreviewRepoPort
ClaimUC --> DocRepoPort
ProcessUC --> DocRepoPort
ProcessUC --> SourceStoragePort
ProcessUC --> ParserPort
ProcessUC --> ChunkerPort
ProcessUC --> VectorPort

DocRepoPort <|.. JdbcRepo
IdPort <|.. UuidGen
SourceStoragePort <|.. LocalStorage
ParserPort <|.. TikaParser
ChunkerPort <|.. ChunkerAdapter
VectorPort <|.. PgVectorAdapter
PreviewRepoPort <|.. JdbcPreviewRepo

JdbcRepo --> PG : ingest_documents
JdbcPreviewRepo --> PG : query vector_store
PgVectorAdapter --> PG : delete + add vectors
PgVectorAdapter --> EmbAPI : embedding
LocalStorage --> FS : save/load file bytes

package "Draft (未实现)" {
  component "ReprocessUseCase" as ReprocessUC
  component "RetryPolicy (3次指数退避+jitter)" as RetryPolicy
}

ReprocessUC ..> ProcessUC : 规划中
RetryPolicy ..> ProcessUC : 规划中

@enduml
