@startuml
title Ingest 处理执行时序图（当前实现）

actor Client
participant "InProcessWorker" as W
participant "ClaimNextUploadedDocumentUseCase" as CUC
participant "ProcessDocumentUseCase" as PUC
participant "DocumentIngestController" as C
participant "GetDocumentChunksPreviewUseCase" as GPUC
participant "DocumentRepository" as R
participant "DocumentChunkPreviewRepository" as CPR
participant "DocumentSourceStorage" as SS
participant "DocumentTextParser" as TP
participant "DocumentChunker" as CH
participant "DocumentVectorIndexer" as VI
database "PostgreSQL" as PG
collections "Local FS" as FS

== Worker 轮询与处理 ==
loop every poll-delay-ms
  W -> CUC : handle()
  CUC -> R : findOldestByStatus(UPLOADED)
  R -> PG : SELECT ... WHERE status=UPLOADED ORDER BY created_at ASC LIMIT 1
  PG --> R : row / empty

  alt 无候选文档
    CUC --> W : Optional.empty
  else 存在候选文档
    CUC -> R : compareAndSetStatus(UPLOADED -> INGESTING)
    R -> PG : UPDATE ... WHERE document_id=? AND status='UPLOADED'
    PG --> R : updatedRows=0/1

    alt 抢占失败（并发变更）
      CUC --> W : Optional.empty
    else 抢占成功
      CUC --> W : Optional.of(documentId)
      W -> PUC : handle(documentId)

      PUC -> R : findById(documentId)
      R -> PG : SELECT by document_id
      PG --> R : Document / empty

      alt 文档不存在或状态非 INGESTING
        PUC --> W : skip
      else 进入处理链路
        PUC -> SS : load(documentId, filename)
        SS -> FS : read file bytes
        FS --> SS : bytes / empty
        SS --> PUC : bytes

        PUC -> TP : parse(filename, bytes)
        TP --> PUC : text
        PUC -> CH : chunk(text)
        CH --> PUC : chunks

        alt chunks 为空或处理异常
          PUC -> R : compareAndSetStatus(INGESTING -> FAILED, reason)
          R -> PG : UPDATE ... WHERE status='INGESTING'
          PG --> R : updatedRows
        else 处理成功
          PUC -> VI : index(document, chunks)
          VI -> PG : delete(chunkIds) + add(vector docs)
          PG --> VI : OK
          PUC -> R : compareAndSetStatus(INGESTING -> INDEXED, null)
          R -> PG : UPDATE ... WHERE status='INGESTING'
          PG --> R : updatedRows
        end
      end
    end
  end
end

== 分块预览查询 ==
Client -> C : GET /api/v1/documents/{id}/chunks/preview?limit&previewChars
C -> GPUC : handle(query)
GPUC -> R : findById(documentId)
R -> PG : SELECT ingest_documents by id
PG --> R : row / empty

alt 文档不存在
  GPUC --> C : throw DocumentNotFoundException
  C --> Client : 404 Not Found
else 文档存在
  GPUC -> CPR : findByDocumentId(documentId, limit)
  CPR -> PG : SELECT vector_store(metadata.documentId)
  PG --> CPR : chunk rows
  CPR --> GPUC : chunk list
  GPUC --> C : DocumentChunksPreviewResult
  C --> Client : 200 preview JSON
end

@enduml
